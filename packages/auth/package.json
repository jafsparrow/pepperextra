{
  "name": "@pepperextra/auth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/auth.js",
      "types": "./src/auth.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "auth:generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config ./src/auth.cli.ts --output ../db/src/auth-schema.ts",
    "auth:migrate": "dotenv -e ../../.env -- better-auth migrate --config ./auth.cli.ts",
    "generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config ./src/auth.cli.ts --output ../db/src/auth-schema.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@pepperextra/db": "workspace:*",
    "@pepperextra/tsconfig": "workspace:*",
    "better-auth": "^1.6.22",
    "drizzle-orm": "1.0.0-rc.4"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
