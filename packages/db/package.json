{
  "name": "@pepperextra/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./drizzle-cli": {
      "default": "./src/drizzle-cli.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    },
    "./auth-schema": {
      "types": "./dist/auth-schema.d.ts",
      "default": "./src/auth-schema.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": " dotenv -e ../../.env -- pnpx drizzle-kit generate",
    "db:push": "dotenv -e ../../.env -- pnpx drizzle-kit push",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "push": "pnpm with-env drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@pepperextra/tsconfig": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.22.4"
  }
}
